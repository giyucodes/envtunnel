{
  "name": "envtunnel",
  "version": "1.0.2",
  "description": "Securely share .env variables via encrypted one-time tokens",
  "type": "module",
  "bin": {
    "envtunnel": "./dist/index.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm",
    "dev": "bun run src/index.ts",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "env",
    "dotenv",
    "secrets",
    "sharing",
    "encrypted",
    "cli",
    "devtools"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "inquirer": "^10.2.2",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}